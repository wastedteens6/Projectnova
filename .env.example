# Database
DATABASE_URL="postgresql://user:password@localhost:5432/projectnova"

# NextAuth
NEXTAUTH_SECRET="your-super-secret-32-character-random-string"
NEXTAUTH_URL="http://localhost:3000"

# App URL (for email links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# AWS S3
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="projectnova-files"
AWS_CLOUDFRONT_URL="https://your-cloudfront-domain.cloudfront.net"

# Razorpay
RAZORPAY_KEY_ID="your_razorpay_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"
RAZORPAY_WEBHOOK_SECRET="your_razorpay_webhook_secret"

# Email & Auth Features
# Set ENABLE_EMAIL=true to send real emails, false to log to console
ENABLE_EMAIL="false"

# Google Drive API (For Project Delivery)
GOOGLE_CLIENT_EMAIL=your-service-account@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Set to false to skip email verification (users can login immediately after registration)
REQUIRE_EMAIL_VERIFICATION="false"
NEXT_PUBLIC_REQUIRE_EMAIL_VERIFICATION="false"

# Set to false to disable password reset feature (hides "Forgot Password" link)
ENABLE_PASSWORD_RESET="false"
NEXT_PUBLIC_ENABLE_PASSWORD_RESET="false"

# SMTP Configuration (only needed if ENABLE_EMAIL=true)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
EMAIL_FROM="ProjectNova <noreply@projectnova.com>"

# Google Analytics
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# App Settings
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="ProjectNova"
