# =============================================
# ProjectNova — Root .gitignore
# =============================================

# -----------------------------
# OS Generated Files
# -----------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------
# Editor / IDE
# -----------------------------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo

# -----------------------------
# Logs
# -----------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------------------
# Dependency Directories
# -----------------------------
node_modules/
bower_components/
jspm_packages/

# -----------------------------
# Build Outputs
# -----------------------------
dist/
build/
out/
coverage/
.next/
.nuxt/
.cache/

# -----------------------------
# Environment Variables
# -----------------------------
.env
.env.*
!.env.example

# -----------------------------
# Temporary / Cache Files
# -----------------------------
*.tmp
*.temp
*.cache
*.pid
*.seed

# -----------------------------
# Package Managers
# -----------------------------
.pnpm-store/
.yarn/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz

# -----------------------------
# TypeScript
# -----------------------------
*.tsbuildinfo

# -----------------------------
# Testing
# -----------------------------
coverage/
.nyc_output/

# -----------------------------
# Misc
# -----------------------------
*.bak
*.orig
*.rej

# -----------------------------
# System Files
# -----------------------------
*.lock-wscript

# Optional: Uncomment if needed
# -----------------------------
# Ignore all lock files (NOT recommended for apps)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml